# Normalize all text to LF on every platform so a Windows checkout
# never rewrites source, fixtures, or signatures to CRLF. The
# catch-all covers any file Git classifies as text; the explicit
# entries pin the formats this project cares about.
* text=auto eol=lf

*.capa   text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.csv    text eol=lf
*.json   text eol=lf
*.asc    text eol=lf
*.sh     text eol=lf
LICENSE  text eol=lf

# The governance pack's reproducibility inputs, pinned LF for defence
# in depth: even if the catch-all above were ever loosened, the epoch
# value generate.sh reads must stay a clean decimal and the script body
# must be byte-stable so the rebuild diffs empty. The five emitted
# artefacts are covered by the *.json rule.
governance/SOURCE_DATE_EPOCH text eol=lf
governance/generate.sh       text eol=lf
